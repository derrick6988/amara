# Example environment variables for Amara
# Copy to .env and fill in values before running

# GitHub token (optional, for GitHubAssistant features)
GITHUB_TOKEN=your_github_token_here

# OpenAI API key (optional). If using Ollama locally, set LLM_PROVIDER=ollama and OLLAMA_URL.
OPENAI_API_KEY=your_openai_api_key_here

# Ollama local server (optional)
OLLAMA_URL=http://localhost:11434

# Which LLM provider to use by default: 'openai' or 'ollama'
LLM_PROVIDER=openai

# Model name to use with your provider
LLM_MODEL=gpt-4o-mini

# Server port (if running a web service)
PORT=3000
